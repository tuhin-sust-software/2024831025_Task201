#include <SDL2/SDL.h>
#include <vector>
#include <string>
#include <cstdlib>
#include <ctime>

const int WINDOW_WIDTH = 640;
const int WINDOW_HEIGHT = 480;
const int BLOCK_SIZE = 20;

class Snake {
public:
    std::vector<SDL_Rect> body;
    int dirX, dirY;

    Snake() {
      
        SDL_Rect head = {WINDOW_WIDTH / 2, WINDOW_HEIGHT / 2, BLOCK_SIZE, BLOCK_SIZE};
        body.push_back(head);
        
        dirX = 0;
        dirY = 0;
    }

    void move() {
       
        if (dirX == 0 && dirY == 0) return;

        for (int i = body.size() - 1; i > 0; i--) {
            body[i].x = body[i - 1].x;
            body[i].y = body[i - 1].y;
        }
        
        body[0].x += dirX;
        body[0].y += dirY;
    }
    void grow() {
       
        SDL_Rect tail = body[body.size() - 1];
        body.push_back(tail);
    }

    bool checkCollision() {
      
        if (body[0].x < 0 || body[0].x >= WINDOW_WIDTH ||
            body[0].y < 0 || body[0].y >= WINDOW_HEIGHT) {
            return true;
        }

        for (size_t i = 1; i < body.size(); i++) {
            if (body[0].x == body[i].x && body[0].y == body[i].y) {
                return true;
            }
        }
        return false;
    }
};
void spawnFood(SDL_Rect& food) {
   
    int maxX = WINDOW_WIDTH / BLOCK_SIZE;
    int maxY = WINDOW_HEIGHT / BLOCK_SIZE;
    
    food.x = (rand() % maxX) * BLOCK_SIZE;
    food.y = (rand() % maxY) * BLOCK_SIZE;
    food.w = BLOCK_SIZE;
    food.h = BLOCK_SIZE;
}

int main(int argc, char* argv[]) {
   
    if (SDL_Init(SDL_INIT_VIDEO) < 0) {
        return -1;
    }

    SDL_Window* window = SDL_CreateWindow("Snake Game - Score: 0", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, WINDOW_WIDTH, WINDOW_HEIGHT, SDL_WINDOW_SHOWN);
    SDL_Renderer* renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);


    srand(time(NULL)); // Seed random number generator
    Snake snake;
    SDL_Rect food;
    spawnFood(food);
    
    int score = 0;
    bool isRunning = true;
    bool isGameOver = false;
    SDL_Event event;

    while (isRunning) {
       
        while (SDL_PollEvent(&event)) {
            if (event.type == SDL_QUIT) {
                isRunning = false;
            }
        
            else if (event.type == SDL_KEYDOWN && !isGameOver) {
                switch (event.key.keysym.sym) {
                    case SDLK_UP:
                        if (snake.dirY != BLOCK_SIZE) { snake.dirX = 0; snake.dirY = -BLOCK_SIZE; }
                        break;
                    case SDLK_DOWN:
                        if (snake.dirY != -BLOCK_SIZE) { snake.dirX = 0; snake.dirY = BLOCK_SIZE; }
                        break;
                    case SDLK_LEFT:
                        if (snake.dirX != BLOCK_SIZE) { snake.dirX = -BLOCK_SIZE; snake.dirY = 0; }
                        break;
                    case SDLK_RIGHT:
                        if (snake.dirX != -BLOCK_SIZE) { snake.dirX = BLOCK_SIZE; snake.dirY = 0; }
                        break;
                }
            }
        }
     if (!isGameOver) {
            snake.move();

          
            if (snake.body[0].x == food.x && snake.body[0].y == food.y) {
                snake.grow();
                score += 10;
                spawnFood(food);
                
                std::string title = "Snake Game - Score: " + std::to_string(score);
                SDL_SetWindowTitle(window, title.c_str());
            }

            if (snake.checkCollision()) {
                isGameOver = true;
                std::string gameOverTitle = "GAME OVER! Final Score: " + std::to_string(score);
                SDL_SetWindowTitle(window, gameOverTitle.c_str());
            }
        }

        SDL_SetRenderDrawColor(renderer, 0, 0, 0, 255);
        SDL_RenderClear(renderer);

        if (!isGameOver) {
            
            SDL_SetRenderDrawColor(renderer, 255, 0, 0, 255);
            SDL_RenderFillRect(renderer, &food);

            SDL_SetRenderDrawColor(renderer, 0, 255, 0, 255);
            for (size_t i = 0; i < snake.body.size(); i++) {
                SDL_RenderFillRect(renderer, &snake.body[i]);
            }
        }

     
        SDL_RenderPresent(renderer);

       
        SDL_Delay(100); 
    }

    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();

    return 0;
}
